# Copy this file to `.env` and fill in real values. Do not commit `.env`.

# ---------- Supabase ----------
# Project Settings -> API in the Supabase dashboard.
# SUPABASE_URL is the project URL, not the dashboard URL — it ends in .supabase.co.
SUPABASE_URL=https://your-project-ref.supabase.co

# "secret" key (server-side only — bypasses Row Level Security).
SUPABASE_SERVICE_KEY=sb_secret_replace_me

# "publishable" key (used to sign users in; safe to ship to clients).
SUPABASE_ANON_KEY=sb_publishable_replace_me

# JWT secret used to verify access tokens LOCALLY on every request,
# instead of calling supabase.auth.get_user (a network round-trip that
# adds ~100-300ms per request). Project Settings -> API -> JWT Settings
# -> JWT Secret. NOT the anon or service-role keys. Leave unset to fall
# back to the slow network path.
SUPABASE_JWT_SECRET=replace_me

# ---------- Anthropic ----------
# Generate at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-replace-me

# ---------- Google Gemini ----------
# Generate at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_me

# ---------- Optional ----------
# Python logging level for app.* loggers. DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins. `*` is fine for local dev;
# set to your real frontend origin(s) in production, e.g.
# ALLOWED_ORIGINS=https://study.yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# Sentry error tracking. Leave SENTRY_DSN empty to disable (default).
# Get a DSN from sentry.io → create a Python project → copy the DSN.
# SENTRY_DSN=https://<key>@<id>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1   # 0.0–1.0; fraction of requests traced
